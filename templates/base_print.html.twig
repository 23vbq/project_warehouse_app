<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Druk{% endblock %} — RimFlowMS</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 13px;
            color: #111;
            background: #fff;
            padding: 32px 40px;
        }

        h1 { font-size: 20px; font-weight: 700; }
        h2 { font-size: 13px; font-weight: 600; margin-bottom: 8px; }

        .document-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 2px solid #111;
        }

        .document-number { font-size: 22px; font-weight: 700; font-family: monospace; }
        .document-type { font-size: 12px; color: #555; margin-top: 2px; }
        .document-meta { text-align: right; font-size: 12px; color: #555; line-height: 1.6; }
        .document-meta strong { color: #111; }

        .section { margin-bottom: 20px; }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px 24px;
            padding: 14px 16px;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        .info-item dt { font-size: 11px; color: #777; margin-bottom: 2px; }
        .info-item dd { font-size: 13px; font-weight: 500; }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

        thead tr { border-bottom: 2px solid #111; }
        tbody tr { border-bottom: 1px solid #e5e5e5; }
        tbody tr:last-child { border-bottom: none; }

        th {
            padding: 7px 8px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        td { padding: 8px; vertical-align: top; }

        .text-right { text-align: right; }
        .font-mono { font-family: monospace; }

        tfoot tr { border-top: 2px solid #111; }
        tfoot td { padding: 8px; font-weight: 600; }

        .signatures {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-top: 48px;
            padding-top: 0;
        }

        .signature-line {
            border-top: 1px solid #aaa;
            padding-top: 6px;
            font-size: 11px;
            color: #777;
            text-align: center;
        }

        .print-btn {
            position: fixed;
            top: 16px;
            right: 16px;
            padding: 8px 16px;
            background: #111;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            cursor: pointer;
        }

        @media print {
            .print-btn { display: none; }
            body { padding: 0; }
            @page { margin: 16mm 20mm; }
        }
    </style>
</head>
<body>

<button class="print-btn" onclick="window.print()">Drukuj</button>

{% block content %}{% endblock %}

</body>
</html>
