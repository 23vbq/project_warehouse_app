<turbo-frame id="product_list">
<div 
    data-controller="turbo-filter"
    data-turbo-filter-url-value="{{ path('app_product_index', { type: filters.type, sort: orderBy.field, direction: orderBy.direction }) }}"
>
    {# Category tabs #}
    <div class="flex items-center gap-1 mb-4 border-b border-stroke">
        {% set tabs = [
            { filter: '', label: 'Wszystkie', color: null },
            { filter: 'finished', label: 'Felgi gotowe', color: 'bg-violet-400' },
            { filter: 'semi', label: 'Półprodukty', color: 'bg-amber-400' },
            { filter: 'raw', label: 'Surowce', color: 'bg-teal-400' },
            { filter: 'consumables', label: 'Materiały eksploatacyjne', color: 'bg-emerald-400' },
        ] %}
        {% for tab in tabs %}
            <a
                href="{{ path('app_product_index', tab.filter ? { type: tab.filter } : {}) }}"
                data-turbo-action="advance"
                class="flex items-center gap-2 px-3.5 py-2.5 text-[13px] font-medium border-b-2 -mb-px transition-colors
                {% if filters.type == tab.filter %}text-brand-400 border-brand-400
                {% else %}text-content-500 border-transparent hover:text-content-50
                {% endif %}
                "
            >
                {% if tab.color %}
                    <span class="w-1.5 h-1.5 rounded-full {{ tab.color }} shrink-0"></span>
                {% endif %}
                {{ tab.label }}
            </a>
        {% endfor %}
    </div>

    {# Filter bar #}
    <div class="flex items-center gap-2 mb-4">
        <div class="flex items-center gap-2 bg-surface-800 border border-stroke rounded-lg h-[34px] px-3 w-72 text-[13px] text-content-500">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.3-4.3"></path></svg>
            <input
                name="query"
                value="{{ filters.query }}"
                data-turbo-filter-target="filterField"
                class="bg-transparent border-0 outline-none flex-1 min-w-0 text-content-50 placeholder:text-content-700 text-[13px]" placeholder="Szukaj po nazwie, SKU, kodzie EAN…"
            >
        </div>

        {% if is_granted('ROLE_WAREHOUSE_MANAGER') %}
            {% set inactiveUrl = path('app_product_index', filters|merge({showInactive: filters.showInactive ? null : 1, page: null, sort: orderBy.field, direction: orderBy.direction})) %}
            <a
                href="{{ inactiveUrl }}"
                class="flex items-center gap-1.5 h-[34px] px-3 text-[13px] border rounded-lg transition-colors
                {% if filters.showInactive %}
                    text-amber-400 bg-amber-500/10 border-amber-500/25 hover:bg-amber-500/15
                {% else %}
                    text-content-500 bg-surface-800 border-stroke hover:text-content-50
                {% endif %}"
            >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                {{ filters.showInactive ? 'Ukryj nieaktywne' : 'Pokaż nieaktywne' }}
            </a>
        {% endif %}

        {# TODO: More filters #}
        {# <button class="flex items-center gap-1.5 h-[34px] px-3 text-[13px] text-content-500 bg-surface-800 border border-stroke rounded-lg hover:text-content-50 transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Lokalizacja: Wszystkie
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
        </button>

        <button class="flex items-center gap-1.5 h-[34px] px-3 text-[13px] text-content-500 bg-surface-800 border border-stroke rounded-lg hover:text-content-50 transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="6" y1="12" x2="18" y2="12"></line><line x1="9" y1="18" x2="15" y2="18"></line></svg>
            Więcej filtrów
        </button> #}
    </div>

    {% include 'product/_list_table.html.twig' %}
</div>
</turbo-frame>
