<div class="bg-surface-900 border border-stroke rounded-xl overflow-hidden mb-3.5">
    <div class="px-5 py-4 border-b border-stroke">
        <div class="text-[14px] font-semibold text-content-50">Stany magazynowe</div>
        <div class="text-[12px] text-content-500 mt-0.5">
            {{ stocks|length }} {{ stocks|length == 1 ? 'lokalizacja' : (stocks|length in [2, 3, 4] ? 'lokalizacje' : 'lokalizacji') }}
        </div>
    </div>

    <table class="w-full text-[13px] table-fixed">
        <colgroup>
            <col class="w-[22%]">
            <col>
            <col class="w-[22%]">
        </colgroup>
        <thead>
            <tr class="border-b border-stroke bg-surface-800/50">
                <th class="px-4 py-2.5 text-left text-[11px] font-medium text-content-500">Lokalizacja</th>
                <th class="px-4 py-2.5 text-left text-[11px] font-medium text-content-500">Nazwa / strefa</th>
                <th class="px-4 py-2.5 text-right text-[11px] font-medium text-content-500">Ilość</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stroke">
            {% for stock in stocks %}
                <tr class="hover:bg-surface-800/30 transition-colors">
                    <td class="px-4 py-3 font-mono text-[12.5px] text-content-50">
                        <a href="{{ path('app_location_index', {query: stock.location.code}) }}" class="underline hover:text-content-300 transition-colors">{{ stock.location.code }}</a>
                    </td>
                    <td class="px-4 py-3 text-content-500 truncate">{{ stock.location.name ?: '—' }}</td>
                    <td class="px-4 py-3 text-right font-mono text-[12.5px] text-content-300">
                        {{ stock.quantity|number_format(3, ',', ' ') }}
                        <span class="text-content-600">{{ product.unit }}</span>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="100%" class="px-4 py-4 text-center text-[13px] text-content-500">Brak stanów magazynowych dla tego produktu.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
