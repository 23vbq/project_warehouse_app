<turbo-frame id="product_new">

{{ form_start(form, {attr: {class: 'flex flex-col', novalidate: 'novalidate'}}) }}

{% set dotColors = {
    'finished':    'bg-violet-400',
    'semi':        'bg-amber-400',
    'raw':         'bg-teal-400',
    'consumables': 'bg-emerald-400',
} %}

<div class="px-[22px] py-[18px] flex flex-col gap-[18px]">

    <div>
        <div class="flex items-center gap-2 mb-3">
            <span class="text-[10.5px] uppercase tracking-[0.08em] font-semibold text-content-700">Kategoria</span>
            <span class="flex-1 h-px bg-stroke"></span>
        </div>
        <div class="grid grid-cols-4 gap-2">
            {% for choice in form.type.vars.choices %}
                <label class="relative cursor-pointer select-none group">
                    <input
                        type="radio"
                        name="{{ form.type.vars.full_name }}"
                        id="{{ form.type.vars.id }}_{{ loop.index0 }}"
                        value="{{ choice.value }}"
                        class="absolute opacity-0 pointer-events-none"
                        {% if choice.value == form.type.vars.value %}checked{% endif %}
                    >
                    <div class="bg-surface-800 border border-stroke rounded-[10px] p-3 transition-all duration-[120ms] group-hover:bg-surface-700 group-hover:border-stroke-strong group-has-[:checked]:bg-brand-500/10 group-has-[:checked]:border-brand-500/40 group-has-[:checked]:shadow-[0_0_0_2px_rgba(160,100,230,0.10)]">
                        <div class="flex items-center justify-between mb-2">
                            <span class="w-[7px] h-[7px] rounded-full {{ dotColors[choice.value] ?? 'bg-content-700' }}"></span>
                            <svg
                                class="w-3.5 h-3.5 text-transparent group-has-[:checked]:text-brand-400 transition-colors"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.6"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            ><path d="M20 6L9 17l-5-5"></path></svg>
                        </div>
                        <div class="text-[12.5px] font-medium text-content-300 group-has-[:checked]:text-brand-400 transition-colors">{{ choice.label }}</div>
                    </div>
                </label>
            {% endfor %}
        </div>
        {{ form_errors(form.type) }}
    </div>

    <div>
        <div class="flex items-center gap-2 mb-3">
            <span class="text-[10.5px] uppercase tracking-[0.08em] font-semibold text-content-700">Dane podstawowe</span>
            <span class="flex-1 h-px bg-stroke"></span>
        </div>
        <div class="grid grid-cols-2 gap-x-4 gap-y-4">
            <div class="col-span-2">
                {{ form_label(form.name, 'Nazwa produktu', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.name, {attr: {placeholder: 'np. Felga aluminiowa 17" ET35'}}) }}
                </span>
                {{ form_errors(form.name) }}
            </div>
            <div>
                {{ form_label(form.sku, 'SKU', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.sku, {attr: {placeholder: 'np. ALU-17-ET35'}}) }}
                </span>
                {{ form_errors(form.sku) }}
            </div>
            <div>
                {{ form_label(form.ean, 'EAN', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.ean, {attr: {placeholder: 'np. 5901234123457'}}) }}
                </span>
                {{ form_errors(form.ean) }}
            </div>
        </div>
    </div>

    <div>
        <div class="flex items-center gap-2 mb-3">
            <span class="text-[10.5px] uppercase tracking-[0.08em] font-semibold text-content-700">Stany i magazyn</span>
            <span class="flex-1 h-px bg-stroke"></span>
        </div>
        <div class="grid grid-cols-3 gap-x-4 gap-y-4">
            <div>
                {{ form_label(form.unit, 'Jednostka miary', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.unit, {attr: {placeholder: 'np. szt., kg, m'}}) }}
                </span>
                {{ form_errors(form.unit) }}
            </div>
            <div>
                {{ form_label(form.unitPrice, 'Cena jednostkowa', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.unitPrice, {attr: {placeholder: '0.00', step: '0.01'}}) }}
                    <span class="text-xs text-content-700 shrink-0">PLN</span>
                </span>
                {{ form_errors(form.unitPrice) }}
            </div>
            <div>
                {{ form_label(form.minStockLevel, 'Min. stan magazynowy', {label_attr: {class: 'block text-xs font-medium text-content-500 mb-1.5'}}) }}
                <span class="input-wrap">
                    {{ form_widget(form.minStockLevel, {attr: {placeholder: '—', step: '0.01'}}) }}
                </span>
                {{ form_errors(form.minStockLevel) }}
            </div>
        </div>
    </div>

</div>

<div class="flex items-center justify-end gap-2 px-[22px] py-4 border-t border-stroke shrink-0">
    <button
        type="button"
        data-modal-hide="modal-product-new"
        class="h-[34px] px-4 text-[13px] font-medium text-content-300 bg-surface-800 border border-stroke rounded-lg hover:bg-surface-700 hover:text-content-50 transition-colors cursor-pointer"
    >
        Anuluj
    </button>
    <button
        type="submit"
        class="h-[34px] px-4 text-[13px] font-medium text-white bg-brand-500 rounded-lg hover:bg-brand-400 transition-colors cursor-pointer"
    >
        Zapisz produkt
    </button>
</div>

{{ form_end(form, {render_rest: false}) }}

</turbo-frame>
