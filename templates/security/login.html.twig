{% extends 'base.html.twig' %}

{% block title %}Logowanie — RimFlowMS{% endblock %}

{% block body %}
<div class="relative min-h-screen grid place-items-center p-6 overflow-hidden login-bg">

    <div class="absolute inset-0 pointer-events-none opacity-35 login-grid"></div>

    <div class="relative z-10 w-full max-w-[420px] bg-surface-900 border border-stroke rounded-[18px] px-8 pt-9 pb-7 login-card-shadow">

        <div class="flex items-center gap-3 mb-6">
            <div class="w-9 h-9 rounded-[10px] border border-stroke-strong grid place-items-center shrink-0 brand-mark-bg">
                <div class="w-1.5 h-1.5 rounded-full bg-brand-500 glow-brand-dot"></div>
            </div>
            <div class="font-semibold tracking-tight leading-tight text-content-50">
                RimFlowMS<br>
                <span class="text-content-500 font-medium text-sm">Warehouse Module</span>
            </div>
        </div>

        <div class="mb-7">
            <h1 class="text-[22px] font-semibold tracking-tight text-content-50 mb-1.5">Zaloguj się do systemu</h1>
            <p class="text-content-500 text-[13.5px]">Moduł magazynowy</p>
        </div>

        {% if error %}
            <div class="mb-4 p-3 rounded-[10px] text-sm bg-danger-500/10 border border-danger-500/30 text-danger-500">
                Niepoprawny login lub hasło.
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" autocomplete="off" novalidate>

            <label class="block mb-3.5">
                <span class="flex justify-between items-center text-xs font-medium text-content-500 mb-1.5">
                    <span>Login lub e-mail</span>
                </span>
                <span class="input-wrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <input type="text" name="_username" value="{{ last_username }}" placeholder="np. j.kowalski" autocomplete="username" required>
                </span>
            </label>

            <label class="block mb-5">
                <span class="flex justify-between items-center text-xs font-medium text-content-500 mb-1.5">
                    Hasło
                </span>
                <span class="input-wrap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="11" width="18" height="11" rx="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <input type="password" name="_password" placeholder="••••••••••" autocomplete="current-password" required>
                </span>
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full h-[42px] bg-brand-500 hover:bg-brand-600 text-[#110d18] font-semibold text-sm rounded-[10px] flex items-center justify-center gap-2 transition-colors cursor-pointer">
                Zaloguj się
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M13 5l7 7-7 7"></path>
                </svg>
            </button>

            <p class="text-center text-content-700 text-xs mt-5">
                Zapomniałeś hasła? Skontaktuj się z administratorem systemu.
            </p>
        </form>
    </div>

    <div class="absolute bottom-5 left-0 right-0 flex justify-center gap-[18px] text-content-700 text-[11.5px] z-10">
        <span class="font-mono">v1.0.0</span>
        <span>© 2026 RimFlowMS</span>
    </div>
</div>

{% endblock %}
