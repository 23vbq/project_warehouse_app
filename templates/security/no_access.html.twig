{% extends 'base.html.twig' %}

{% block title %}No Access{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="bg-white p-8 rounded-lg shadow-md text-center">
            <h1 class="text-2xl font-bold mb-4 text-red-600">Access denied</h1>
            <p class="text-gray-600 mb-6">You do not have permission to access this page.</p>
            <a href="{{ path('app_public') }}" class="bg-gray-600 hover:bg-gray-700 text-white font-medium px-5 py-2 rounded">
                Go back
            </a>
        </div>
    </div>
{% endblock %}
