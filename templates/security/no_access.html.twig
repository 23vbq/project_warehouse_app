{% extends 'layout/app.html.twig' %}

{% block title %}Brak dostępu — RimFlowMS{% endblock %}

{% block breadcrumb_current %}Brak dostępu{% endblock %}

{% block content %}
<div class="flex flex-col items-center justify-center h-full min-h-[60vh] text-center">
    <div class="w-16 h-16 rounded-2xl bg-danger-500/10 border border-danger-500/20 grid place-items-center mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-danger-400">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
    </div>

    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-content-700 mb-2">Błąd 403</p>
    <h1 class="text-[26px] font-semibold tracking-tight text-content-50 mb-3">Brak dostępu</h1>
    <p class="text-[14px] text-content-500 max-w-sm leading-relaxed mb-8">
        Nie masz uprawnień do wyświetlenia tej strony.<br>
        Skontaktuj się z administratorem, jeśli uważasz, że to błąd.
    </p>

    <a
        href="{{ path('app_default') }}"
        class="flex items-center gap-2 h-[36px] px-5 text-[13px] font-medium text-content-300 bg-surface-800 border border-stroke rounded-lg hover:bg-surface-700 hover:text-content-50 transition-colors"
    >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
        Wróć do strony głównej
    </a>
</div>
{% endblock %}
