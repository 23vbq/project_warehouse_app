{% extends 'base.html.twig' %}

{% block title %}Protected page{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="bg-white p-8 rounded-lg shadow-md text-center">
            <h1 class="text-2xl font-bold mb-4 text-gray-800">Protected page</h1>
            <p class="text-gray-600 mb-6">Logged in as: <span class="font-semibold text-blue-600">{{ app.user.getUserIdentifier() }}</span></p>
            <a href="{{ path('app_logout') }}" class="bg-red-500 hover:bg-red-600 text-white font-medium px-5 py-2 rounded">
                Log out
            </a>
        </div>
    </div>
{% endblock %}
