{% extends 'layout/app.html.twig' %}

{% block title %}{{ operation.fullNumber }} — RimFlowMS{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_operation_index') }}" class="hover:text-content-300 transition-colors">Operacje</a>
    <span class="text-content-700">/</span>
    <span class="text-content-50 font-mono font-medium">{{ operation.fullNumber }}</span>
{% endblock %}

{% macro field(label, value) %}
<div>
    <dt class="text-[11px] uppercase tracking-[0.07em] font-semibold text-content-700 mb-1.5">{{ label }}</dt>
    <dd class="text-[13px] text-content-50">{{ value is not empty ? value : '—' }}</dd>
</div>
{% endmacro %}

{% block content %}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a
            href="{{ path('app_operation_index') }}"
            class="w-[34px] h-[34px] rounded-lg bg-surface-800 border border-stroke flex items-center justify-center text-content-500 hover:text-content-50 hover:bg-surface-700 transition-colors"
        >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
        </a>
        <div class="flex items-center gap-2.5">
            <h1 class="text-[22px] font-semibold tracking-tight text-content-50 font-mono">{{ operation.fullNumber }}</h1>
            {{ include('operation/_partials/type.html.twig', {operation: operation}) }}
            {{ include('operation/_partials/status.html.twig', {operation: operation}) }}
        </div>
    </div>

    {% if operation.status.value == 'draft' %}
    <form method="post" action="{{ path('app_operation_confirm', {id: operation.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('confirm_operation_' ~ operation.id) }}">
        <button
            type="submit"
            class="flex items-center gap-2 h-[34px] px-4 text-[13px] font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-500 transition-colors cursor-pointer"
        >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Zatwierdź
        </button>
    </form>
    {% endif %}
</div>

<div class="flex flex-col gap-4">

    {# Metadata card #}
    <div class="bg-surface-900 border border-stroke rounded-xl p-4">
        <dl class="flex items-start gap-10 text-[13px]">
            <div>
                <dt class="text-[11px] uppercase tracking-[0.07em] font-semibold text-content-700 mb-1">Utworzono</dt>
                <dd class="text-content-50">{{ operation.createdAt|date('d.m.Y H:i') }}</dd>
                <dd class="text-content-500 text-[11px] mt-0.5">{{ operation.createdBy ? operation.createdBy.getUserIdentifier() : '—' }}</dd>
            </div>
            {% if operation.confirmedAt %}
            <div>
                <dt class="text-[11px] uppercase tracking-[0.07em] font-semibold text-content-700 mb-1">Zatwierdzono</dt>
                <dd class="text-content-50">{{ operation.confirmedAt|date('d.m.Y H:i') }}</dd>
                <dd class="text-content-500 text-[11px] mt-0.5">{{ operation.confirmedBy ? operation.confirmedBy.getUserIdentifier() : '—' }}</dd>
            </div>
            {% endif %}
        </dl>
    </div>

    {# Document header card #}
    <div class="bg-surface-900 border border-stroke rounded-xl p-5">
        <div class="flex items-center gap-2 mb-4">
            <span class="text-[10.5px] uppercase tracking-[0.08em] font-semibold text-content-700">Dane dokumentu</span>
            <span class="flex-1 h-px bg-stroke"></span>
        </div>
        <dl class="grid grid-cols-4 gap-x-6 gap-y-5">
            {{ _self.field('Data dokumentu', operation.documentDate|date('d.m.Y')) }}

            {% if operation.documentType == 'receipt' %}
                {{ _self.field('Dostawca', operation.supplier) }}
                {{ _self.field('Nr faktury / WZ dostawcy', operation.invoiceNumber) }}
                {{ _self.field('Data dostawy', operation.deliveryDate ? operation.deliveryDate|date('d.m.Y') : null) }}
                {{ _self.field('Transport', operation.transport) }}
            {% elseif operation.documentType == 'release' %}
                {{ _self.field('Odbiorca', operation.recipient) }}
                {{ _self.field('Nr zamówienia klienta', operation.customerOrderNumber) }}
                {{ _self.field('Data wydania', operation.releaseDate ? operation.releaseDate|date('d.m.Y') : null) }}
                {{ _self.field('Sposób wydania', operation.releaseMethod) }}
            {% elseif operation.documentType == 'relocation' %}
                {{ _self.field('Powód przesunięcia', operation.reason) }}
            {% endif %}
        </dl>
    </div>

    {# Lines card #}
    {{ include('operation/_partials/' ~ operation.documentType ~ '_show_lines.html.twig', {operation: operation}) }}

</div>

{% endblock %}
