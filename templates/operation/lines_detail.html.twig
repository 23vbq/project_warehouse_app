<turbo-frame id="operation-lines-details-{{ operation.id }}">
    {% if operation.operationLines is empty %}
        <p class="px-4 py-3 text-[13px] text-content-500">Brak pozycji.</p>
    {% else %}
        <table class="w-full text-[13px] table-fixed">
            <colgroup>
                <col class="w-8">
                <col class="w-[35%]">
                {% if operation.documentType == 'relocation' %}
                    <col class="w-[20%]">
                    <col class="w-[20%]">
                {% else %}
                    <col class="w-[22%]">
                    <col class="w-[12%]">
                    <col class="w-[12%]">
                {% endif %}
                <col class="w-[13%]">
            </colgroup>
            <thead>
                <tr class="border-b border-stroke bg-surface-800/30">
                    <th class="px-3 py-2 text-left text-[11px] font-medium text-content-700">#</th>
                    <th class="px-3 py-2 text-left text-[11px] font-medium text-content-500">Produkt / SKU</th>
                    {% if operation.documentType == 'relocation' %}
                        <th class="px-3 py-2 text-left text-[11px] font-medium text-content-500">Skąd</th>
                        <th class="px-3 py-2 text-left text-[11px] font-medium text-content-500">Dokąd</th>
                    {% elseif operation.documentType == 'receipt' %}
                        <th class="px-3 py-2 text-left text-[11px] font-medium text-content-500">Lokalizacja</th>
                        <th class="px-3 py-2 text-right text-[11px] font-medium text-content-500">Cena jedn.</th>
                        <th class="px-3 py-2 text-right text-[11px] font-medium text-content-500">Wartość</th>
                    {% else %}
                        <th class="px-3 py-2 text-left text-[11px] font-medium text-content-500">Lokalizacja</th>
                        <th class="px-3 py-2 text-right text-[11px] font-medium text-content-500">Cena jedn.</th>
                        <th class="px-3 py-2 text-right text-[11px] font-medium text-content-500">Wartość</th>
                    {% endif %}
                    <th class="px-3 py-2 text-right text-[11px] font-medium text-content-500">Ilość</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-stroke">
                {% for line in operation.operationLines %}
                    <tr>
                        <td class="px-3 py-2 text-content-700 text-[11px]">{{ loop.index }}</td>
                        <td class="px-3 py-2 min-w-0">
                            <div class="text-content-50 truncate">{{ line.product.name }}</div>
                            <div class="font-mono text-[11.5px] text-content-500 truncate mt-0.5">{{ line.product.sku }}</div>
                        </td>
                        {% if operation.documentType == 'relocation' %}
                            <td class="px-3 py-2 font-mono text-[12px] text-content-300">{{ line.locationFrom ? line.locationFrom.code : '—' }}</td>
                            <td class="px-3 py-2 font-mono text-[12px] text-content-300">{{ line.locationTo ? line.locationTo.code : '—' }}</td>
                        {% elseif operation.documentType == 'receipt' %}
                            <td class="px-3 py-2 font-mono text-[12px] text-content-300">{{ line.locationTo ? line.locationTo.code : '—' }}</td>
                            <td class="px-3 py-2 text-right text-content-300 tabular-nums">{{ line.unitPrice ? line.unitPrice|number_format(2, ',', ' ') : '—' }}</td>
                            <td class="px-3 py-2 text-right text-content-300 tabular-nums">{{ (line.unitPrice and line.quantity) ? (line.quantity * line.unitPrice)|number_format(2, ',', ' ') : '—' }}</td>
                        {% else %}
                            <td class="px-3 py-2 font-mono text-[12px] text-content-300">{{ line.locationFrom ? line.locationFrom.code : '—' }}</td>
                            <td class="px-3 py-2 text-right text-content-300 tabular-nums">{{ line.unitPrice ? line.unitPrice|number_format(2, ',', ' ') : '—' }}</td>
                            <td class="px-3 py-2 text-right text-content-300 tabular-nums">{{ (line.unitPrice and line.quantity) ? (line.quantity * line.unitPrice)|number_format(2, ',', ' ') : '—' }}</td>
                        {% endif %}
                        <td class="px-3 py-2 text-right tabular-nums">
                            <span class="font-medium text-content-50">{{ line.quantity|number_format(3, ',', ' ') }}</span>
                            <span class="text-content-500 text-[11px]">{{ line.product.unit }}</span>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</turbo-frame>
