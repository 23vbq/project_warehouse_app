{% set types = {
    receipt: {label: 'PZ', icon: 'svg/pz.svg', class: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20'},
    release: {label: 'WZ', icon: 'svg/wz.svg', class: 'text-violet-400 bg-violet-500/10 border-violet-500/20'},
    relocation: {label: 'MM', icon: 'svg/mm.svg', class: 'text-amber-400 bg-amber-500/10 border-amber-500/20'},
} %}
{% set t = types[operation.documentType] ?? null %}
{% if t %}
    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded border text-[11px] font-medium {{ t.class }}">
        <div class="w-3 h-3 shrink-0">{{ source(t.icon) }}</div>
        {{ t.label }}
    </span>
{% endif %}
