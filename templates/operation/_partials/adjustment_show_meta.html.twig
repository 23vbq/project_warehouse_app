{% set gains = operation.operationLines|filter(l => l.locationTo is not null)|length %}
{% set losses = operation.operationLines|filter(l => l.locationFrom is not null)|length %}

<div class="grid grid-cols-4 border border-stroke rounded-xl overflow-hidden bg-surface-900 mb-4">

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Inwentaryzacja</div>
            {% if operation.stocktaking %}
                <a href="{{ path('app_stocktaking_show', {id: operation.stocktaking.id}) }}" class="font-mono text-[13px] text-content-50 font-medium mt-0.5 underline hover:text-content-300 transition-colors block">#{{ operation.stocktaking.id }}</a>
            {% else %}
                <div class="text-[13px] text-content-700 mt-0.5">—</div>
            {% endif %}
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Data dokumentu</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5">{{ operation.documentDate|date('d.m.Y') }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Zyski</div>
            <div class="font-mono text-[13px] font-medium mt-0.5 {{ gains > 0 ? 'text-emerald-400' : 'text-content-700' }}">{{ gains }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Straty</div>
            <div class="font-mono text-[13px] font-medium mt-0.5 {{ losses > 0 ? 'text-danger-500' : 'text-content-700' }}">{{ losses }}</div>
        </div>
    </div>

</div>
