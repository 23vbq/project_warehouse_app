        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Dostawca</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.supplier ?: '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Nr faktury / WZ</div>
        <div class="text-[13px] text-content-50 font-mono mt-1">{{ operation.invoiceNumber ?: '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Data dostawy</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.deliveryDate ? operation.deliveryDate|date('d.m.Y') : '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Transport</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.transport ?: '—' }}</div>
