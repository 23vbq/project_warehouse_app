<div class="grid grid-cols-4 border border-stroke rounded-xl overflow-hidden bg-surface-900 mb-4">

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"></path></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Powód</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5 truncate">{{ operation.reason ?: '—' }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Data dokumentu</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5">{{ operation.documentDate|date('d.m.Y') }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Operator</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5 truncate">{{ operation.createdBy ? operation.createdBy.getUserIdentifier() : '—' }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Wartość netto</div>
            <div class="text-[13px] text-content-700 font-medium mt-0.5">—</div>
            <div class="text-[11px] text-content-700 mt-0.5">przesunięcie wewnętrzne</div>
        </div>
    </div>

</div>
