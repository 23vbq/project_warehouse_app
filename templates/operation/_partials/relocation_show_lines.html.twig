<div class="bg-surface-900 border border-stroke rounded-xl overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-stroke">
        <div>
            <div class="text-[14px] font-semibold text-content-50">Pozycje dokumentu</div>
            <div class="text-[12px] text-content-500 mt-0.5">
                {{ operation.operationLines|length }} {{ operation.operationLines|length == 1 ? 'pozycja' : (operation.operationLines|length in [2, 3, 4] ? 'pozycje' : 'pozycji') }}
            </div>
        </div>
    </div>

    <table class="w-full text-[13px] table-fixed">
        <colgroup>
            <col class="w-8">
            <col class="w-[34%]">
            <col class="w-[22%]">
            <col class="w-[22%]">
            <col class="w-[14%]">
        </colgroup>
        <thead>
            <tr class="border-b border-stroke bg-surface-800/50">
                <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-700">#</th>
                <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Produkt / SKU</th>
                <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Lokalizacja źródłowa</th>
                <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Lokalizacja docelowa</th>
                <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Ilość</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stroke">
        {% for line in operation.operationLines %}
            <tr class="hover:bg-surface-800/30 transition-colors">
                <td class="px-3 py-3 text-content-700 text-[11px]">{{ loop.index }}</td>
                <td class="px-3 py-3 min-w-0">
                    <div class="text-[13px] text-content-50 leading-tight truncate">{{ line.product.name }}</div>
                    <div class="font-mono text-[11.5px] text-content-500 leading-tight truncate mt-0.5">{{ line.product.sku }}</div>
                </td>
                <td class="px-3 py-3">
                    {% if line.locationFrom %}
                        <div class="font-mono text-[12.5px] text-content-50 leading-tight">{{ line.locationFrom.code }}</div>
                        {% if line.locationFrom.name %}
                            <div class="text-[11px] text-content-500 leading-tight mt-0.5 truncate">{{ line.locationFrom.name }}</div>
                        {% endif %}
                    {% else %}
                        <span class="text-content-700">—</span>
                    {% endif %}
                </td>
                <td class="px-3 py-3">
                    {% if line.locationTo %}
                        <div class="font-mono text-[12.5px] text-content-50 leading-tight">{{ line.locationTo.code }}</div>
                        {% if line.locationTo.name %}
                            <div class="text-[11px] text-content-500 leading-tight mt-0.5 truncate">{{ line.locationTo.name }}</div>
                        {% endif %}
                    {% else %}
                        <span class="text-content-700">—</span>
                    {% endif %}
                </td>
                <td class="px-3 py-3 text-right tabular-nums">
                    <span class="inline-flex items-center gap-1 font-medium {{ isConfirmed ? 'text-content-50' : 'text-content-500' }}"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>{{ line.quantity|number_format(3, ',', ' ') }}</span>
                    <span class="text-content-500 text-[11px]">{{ line.product.unit }}</span>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
