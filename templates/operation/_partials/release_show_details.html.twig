<div class="bg-surface-900 border border-stroke rounded-xl p-4 mb-3.5 flex flex-col gap-3">
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Odbiorca</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.recipient ?: '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Nr zamówienia klienta</div>
        <div class="text-[13px] text-content-50 font-mono mt-1">{{ operation.customerOrderNumber ?: '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Data wydania</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.releaseDate ? operation.releaseDate|date('d.m.Y') : '—' }}</div>
    </div>
    <div>
        <div class="text-[11px] text-content-500 uppercase tracking-[0.06em] font-semibold">Sposób wydania</div>
        <div class="text-[13px] text-content-50 mt-1">{{ operation.releaseMethod ?: '—' }}</div>
    </div>
</div>
