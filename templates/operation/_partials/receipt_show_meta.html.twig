{% set totalValue = 0 %}
{% for line in operation.operationLines %}
    {% if line.unitPrice and line.quantity %}
        {% set totalValue = totalValue + (line.quantity * line.unitPrice) %}
    {% endif %}
{% endfor %}

<div class="grid grid-cols-5 border border-stroke rounded-xl overflow-hidden bg-surface-900 mb-4">

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Dostawca</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5 truncate">{{ operation.supplier ?: '—' }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Nr faktury / WZ</div>
            <div class="font-mono text-[13px] text-content-300 font-medium mt-0.5 truncate">{{ operation.invoiceNumber ?: '—' }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Data dostawy</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5">{{ operation.deliveryDate ? operation.deliveryDate|date('d.m.Y') : '—' }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 border-r border-stroke min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Data dokumentu</div>
            <div class="text-[13px] text-content-50 font-medium mt-0.5">{{ operation.documentDate|date('d.m.Y') }}</div>
        </div>
    </div>

    <div class="flex gap-3 p-4 min-w-0">
        <div class="w-7 h-7 rounded-lg bg-surface-700 border border-stroke text-content-500 grid place-items-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
        </div>
        <div class="min-w-0">
            <div class="text-[10.5px] uppercase tracking-[0.06em] font-semibold text-content-700">Wartość netto</div>
            {% if totalValue > 0 %}
                <div class="font-mono text-[13px] text-content-50 font-medium mt-0.5 tabular-nums">{{ totalValue|number_format(2, ',', ' ') }} PLN</div>
            {% else %}
                <div class="text-[13px] text-content-700 font-medium mt-0.5">—</div>
            {% endif %}
        </div>
    </div>

</div>
