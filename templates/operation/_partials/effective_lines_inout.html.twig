{#
  Shared table partial for receipt and release effective lines (no card wrapper).
  The card + header is rendered by the caller.
  Required parameters:
    effectiveLines    — OperationLine[]
    locationHeader    — column header, e.g. 'Lokalizacja docelowa'
    locationField     — 'locationTo' or 'locationFrom'
    quantitySign      — '+' or '−'
    quantityColor     — Tailwind class, e.g. 'text-emerald-400' or 'text-violet-400'
#}
{% set totalValue = 0 %}
{% for line in effectiveLines %}
    {% if line.product.unitPrice and line.quantity %}
        {% set totalValue = totalValue + (line.quantity * line.product.unitPrice) %}
    {% endif %}
{% endfor %}

<table class="w-full text-[13px] table-fixed">
    <colgroup>
        <col class="w-8">
        <col class="w-[34%]">
        <col class="w-[22%]">
        <col class="w-[15%]">
        <col class="w-[13%]">
        <col class="w-[13%]">
    </colgroup>
    <thead>
        <tr class="border-b border-stroke bg-surface-800/50">
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-700">#</th>
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Produkt / SKU</th>
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">{{ locationHeader }}</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Ilość</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Cena jedn.</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Wartość</th>
        </tr>
    </thead>
    <tbody class="divide-y divide-stroke">
    {% for line in effectiveLines %}
        {% set loc = attribute(line, locationField) %}
        <tr class="hover:bg-surface-800/30 transition-colors">
            <td class="px-3 py-3 text-content-700 text-[11px]">{{ loop.index }}</td>
            <td class="px-3 py-3 min-w-0">
                <a href="{{ path('app_product_show', {id: line.product.id}) }}" class="text-[13px] font-medium text-content-50 leading-tight truncate underline hover:text-content-300 transition-colors block">{{ line.product.name }}</a>
                <div class="font-mono text-[11.5px] text-content-500 leading-tight truncate mt-0.5">{{ line.product.sku }}</div>
            </td>
            <td class="px-3 py-3">
                {% if loc %}
                    <div class="font-mono text-[12.5px] text-content-50 leading-tight">{{ loc.code }}</div>
                    {% if loc.name %}
                        <div class="text-[11px] text-content-500 leading-tight mt-0.5 truncate">{{ loc.name }}</div>
                    {% endif %}
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
            <td class="px-3 py-3 text-right tabular-nums">
                <span class="font-mono text-[12.5px] {{ quantityColor }}">{{ quantitySign }}{{ line.quantity|number_format(3, ',', ' ') }}</span>
                <span class="text-content-500">{{ line.product.unit }}</span>
            </td>
            <td class="px-3 py-3 text-right text-content-300 tabular-nums font-mono text-[12.5px]">
                {% if line.product.unitPrice %}
                    {{ line.product.unitPrice|number_format(2, ',', ' ') }}
                    <span class="text-content-500">PLN</span>
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
            <td class="px-3 py-3 text-right text-content-50 tabular-nums font-mono text-[12.5px] font-medium">
                {% if line.product.unitPrice and line.quantity %}
                    {{ (line.quantity * line.product.unitPrice)|number_format(2, ',', ' ') }}
                    <span class="text-content-500 font-normal">PLN</span>
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
        </tr>
    {% endfor %}
    </tbody>
    {% if totalValue > 0 %}
        <tfoot>
            <tr class="border-t border-stroke bg-surface-800/50">
                <td colspan="5" class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500 uppercase tracking-[0.06em]">Suma netto</td>
                <td class="px-3 py-2.5 text-right font-mono text-[12.5px] font-medium text-content-50 tabular-nums">
                    {{ totalValue|number_format(2, ',', ' ') }}
                    <span class="text-content-500 font-normal">PLN</span>
                </td>
            </tr>
        </tfoot>
    {% endif %}
</table>
