{% set totalValue = 0 %}
{% for line in operation.operationLines %}
    {% if line.product.unitPrice and line.quantity %}
        {% set totalValue = totalValue + (line.quantity * line.product.unitPrice) %}
    {% endif %}
{% endfor %}

<table class="w-full text-[13px] table-fixed">
    <colgroup>
        <col class="w-8">
        <col>
        <col class="w-[16%]">
        <col class="w-[16%]">
        <col class="w-[13%]">
        <col class="w-[12%]">
        <col class="w-[12%]">
    </colgroup>
    <thead>
        <tr class="border-b border-stroke bg-surface-800/50">
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-700">#</th>
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Produkt / SKU</th>
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Skąd</th>
            <th class="px-3 py-2.5 text-left text-[11px] font-medium text-content-500">Dokąd</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Ilość</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Cena jedn.</th>
            <th class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500">Wartość</th>
        </tr>
    </thead>
    <tbody class="divide-y divide-stroke">
    {% for line in operation.operationLines %}
        {% set isInflow = line.locationTo is not null and line.locationFrom is null %}
        {% set isOutflow = line.locationFrom is not null and line.locationTo is null %}
        <tr class="hover:bg-surface-800/30 transition-colors">
            <td class="px-3 py-3 text-content-700 text-[11px]">{{ loop.index }}</td>
            <td class="px-3 py-3 min-w-0">
                <a href="{{ path('app_product_show', {id: line.product.id}) }}" class="text-[13px] font-medium text-content-50 leading-tight truncate underline hover:text-content-300 transition-colors block">{{ line.product.name }}</a>
                <div class="font-mono text-[11.5px] text-content-500 leading-tight truncate mt-0.5">{{ line.product.sku }}</div>
            </td>
            <td class="px-3 py-3">
                {% if line.locationFrom %}
                    <div class="font-mono text-[12.5px] text-content-50 leading-tight">{{ line.locationFrom.code }}</div>
                    {% if line.locationFrom.name %}
                        <div class="text-[11px] text-content-500 leading-tight mt-0.5 truncate">{{ line.locationFrom.name }}</div>
                    {% endif %}
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
            <td class="px-3 py-3">
                {% if line.locationTo %}
                    <div class="font-mono text-[12.5px] text-content-50 leading-tight">{{ line.locationTo.code }}</div>
                    {% if line.locationTo.name %}
                        <div class="text-[11px] text-content-500 leading-tight mt-0.5 truncate">{{ line.locationTo.name }}</div>
                    {% endif %}
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
            <td class="px-3 py-3 text-right tabular-nums">
                {% if operation.isConfirmed %}
                    {% if isInflow %}
                        <span class="font-mono text-[12.5px] text-emerald-400">+{{ line.quantity|number_format(3, ',', ' ') }}</span>
                    {% elseif isOutflow %}
                        <span class="font-mono text-[12.5px] text-rose-400">−{{ line.quantity|number_format(3, ',', ' ') }}</span>
                    {% else %}
                        <span class="inline-flex items-center justify-end gap-1 font-mono text-[12.5px] text-content-50">
                            <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>
                            {{ line.quantity|number_format(3, ',', ' ') }}
                        </span>
                    {% endif %}
                {% else %}
                    <span class="font-mono text-[12.5px] text-content-300">{{ line.quantity|number_format(3, ',', ' ') }}</span>
                {% endif %}
                <span class="text-content-500">{{ line.product.unit }}</span>
            </td>
            <td class="px-3 py-3 text-right text-content-300 tabular-nums font-mono text-[12.5px]">
                {% if line.product.unitPrice %}
                    {{ line.product.unitPrice|number_format(2, ',', ' ') }}
                    <span class="text-content-500">PLN</span>
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
            <td class="px-3 py-3 text-right text-content-50 tabular-nums font-mono text-[12.5px] font-medium">
                {% if line.product.unitPrice and line.quantity %}
                    {{ (line.quantity * line.product.unitPrice)|number_format(2, ',', ' ') }}
                    <span class="text-content-500 font-normal">PLN</span>
                {% else %}
                    <span class="text-content-700">—</span>
                {% endif %}
            </td>
        </tr>
    {% endfor %}
    </tbody>
    {% if totalValue > 0 %}
        <tfoot>
            <tr class="border-t border-stroke bg-surface-800/50">
                <td colspan="6" class="px-3 py-2.5 text-right text-[11px] font-medium text-content-500 uppercase tracking-[0.06em]">Suma netto</td>
                <td class="px-3 py-2.5 text-right font-mono text-[12.5px] font-medium text-content-50 tabular-nums">
                    {{ totalValue|number_format(2, ',', ' ') }}
                    <span class="text-content-500 font-normal">PLN</span>
                </td>
            </tr>
        </tfoot>
    {% endif %}
</table>
