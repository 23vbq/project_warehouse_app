{% extends 'base_print.html.twig' %}

{% block title %}{{ operation.fullNumber }}{% endblock %}

{% block content %}

<div class="document-header">
    <div>
        <div class="document-number">{{ operation.fullNumber }}</div>
        <div class="document-type">Przesunięcie międzymagazynowe (MM)</div>
    </div>
    <div class="document-meta">
        <div>Data dokumentu: <strong>{{ operation.documentDate|date('d.m.Y') }}</strong></div>
        <div>Zatwierdzono: <strong>{{ operation.confirmedAt|date('d.m.Y H:i') }}</strong></div>
        <div>Zatwierdził: <strong>{{ operation.confirmedBy ? operation.confirmedBy.getUserIdentifier() : '—' }}</strong></div>
    </div>
</div>

<div class="section">
    <div class="info-grid">
        <div class="info-item">
            <dt>Operator</dt>
            <dd>{{ operation.createdBy ? operation.createdBy.getUserIdentifier() : '—' }}</dd>
        </div>
        <div class="info-item">
            <dt>Utworzono</dt>
            <dd>{{ operation.createdAt|date('d.m.Y H:i') }}</dd>
        </div>
        <div class="info-item">
            <dt>Liczba pozycji</dt>
            <dd>{{ operation.operationLines|length }}</dd>
        </div>
    </div>
</div>

<div class="section">
    <h2>Pozycje dokumentu</h2>
    <table>
        <thead>
            <tr>
                <th style="width:30px">#</th>
                <th>Produkt</th>
                <th>SKU</th>
                <th>Skąd</th>
                <th>Dokąd</th>
                <th class="text-right">Ilość</th>
            </tr>
        </thead>
        <tbody>
            {% for line in operation.operationLines %}
                <tr>
                    <td class="font-mono">{{ loop.index }}</td>
                    <td>{{ line.product ? line.product.name : '—' }}</td>
                    <td class="font-mono">{{ line.product ? line.product.sku : '—' }}</td>
                    <td class="font-mono">{{ line.locationFrom ? line.locationFrom.code : '—' }}</td>
                    <td class="font-mono">{{ line.locationTo ? line.locationTo.code : '—' }}</td>
                    <td class="text-right font-mono">{{ line.quantity|number_format(3, ',', ' ') }} {{ line.product ? line.product.unit : '' }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="signatures">
    <div class="signature-line">Przesunął</div>
    <div class="signature-line">Zatwierdził</div>
</div>

{% endblock %}
