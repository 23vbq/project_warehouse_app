<turbo-frame id="stocktaking_list">
<div
    data-controller="turbo-filter"
    data-turbo-filter-url-value="{{ path('app_stocktaking_index', {sort: orderBy.field, direction: orderBy.direction}) }}"
>
    <div class="flex items-center gap-2 mb-4">
        <div class="flex items-center gap-2 bg-surface-800 border border-stroke rounded-lg h-[34px] px-3 w-72 text-[13px] text-content-500">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.3-4.3"></path></svg>
            <input
                name="query"
                value="{{ filters.query }}"
                data-turbo-filter-target="filterField"
                class="bg-transparent border-0 outline-none flex-1 min-w-0 text-content-50 placeholder:text-content-700 text-[13px]"
                placeholder="Szukaj po ID…"
            >
        </div>
    </div>

    {{ include('stocktaking/_list_table.html.twig') }}
</div>
</turbo-frame>
