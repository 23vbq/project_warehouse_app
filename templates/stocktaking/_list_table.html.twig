<div class="bg-surface-900 border border-stroke rounded-xl overflow-hidden">
    <table class="w-full text-[13px] table-fixed">
        <colgroup>
            <col class="w-[18%]">
            <col class="w-[14%]">
            <col class="w-[18%]">
            <col class="w-[14%]">
            <col class="w-[18%]">
            <col class="w-[18%]">
        </colgroup>
        <thead>
            <tr class="border-b border-stroke">
                <th class="px-4 py-3 text-left font-medium text-content-500">Utworzono</th>
                <th class="px-4 py-3 text-left font-medium text-content-500">Operator</th>
                <th class="px-4 py-3 text-left font-medium text-content-500">Status</th>
                <th class="px-4 py-3 text-right font-medium text-content-500">Linie</th>
                <th class="px-4 py-3 text-left font-medium text-content-500">Dokument</th>
                <th class="px-4 py-3 text-left font-medium text-content-500">Zakończono</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stroke">
            {% for stocktaking in pager %}
                <tr class="hover:bg-surface-800/50 transition-colors cursor-pointer" onclick="window.location='{{ path('app_stocktaking_show', {id: stocktaking.id}) }}'">
                    <td class="px-4 py-3">
                        <div class="text-content-50 font-medium">{{ stocktaking.createdAt|date('d.m.Y') }}</div>
                        <div class="text-content-700 text-[11px]">{{ stocktaking.createdAt|date('H:i') }}</div>
                    </td>
                    <td class="px-4 py-3 text-content-300 truncate">
                        {{ stocktaking.createdBy ? stocktaking.createdBy.getUserIdentifier() : '—' }}
                    </td>
                    <td class="px-4 py-3">
                        {{ include('stocktaking/_partials/status.html.twig') }}
                    </td>
                    <td class="px-4 py-3 text-right font-mono text-content-300">
                        {% set counted = stocktaking.stocktakingLines|filter(l => l.countedQuantity is not null)|length %}
                        {% set total = stocktaking.stocktakingLines|length %}
                        <span class="{{ counted == total ? 'text-emerald-400' : 'text-content-300' }}">{{ counted }}</span>
                        <span class="text-content-700">/</span>
                        {{ total }}
                    </td>
                    <td class="px-4 py-3">
                        {% if stocktaking.adjustment %}
                            <a
                                href="{{ path('app_operation_show', {id: stocktaking.adjustment.id}) }}"
                                class="font-mono text-[12px] font-medium text-content-50 underline hover:text-content-300 transition-colors"
                                onclick="event.stopPropagation()"
                            >{{ stocktaking.adjustment.fullNumber }}</a>
                        {% else %}
                            <span class="text-content-700">—</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3 text-content-500">
                        {% if stocktaking.completedAt %}
                            {{ stocktaking.completedAt|date('d.m.Y H:i') }}
                        {% else %}
                            —
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="100%" class="px-4 py-6 text-center text-content-500">Brak inwentaryzacji.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {{ pagerfanta(pager) }}
</div>
