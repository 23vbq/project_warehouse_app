{% extends 'layout/app.html.twig' %}

{% block title %}Inwentaryzacje — RimFlowMS{% endblock %}

{% block breadcrumb_current %}Inwentaryzacje{% endblock %}

{% block content %}
<turbo-frame id="page_content" data-turbo="true">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-[22px] font-semibold tracking-tight text-content-50 mb-1">Inwentaryzacje</h1>
            <p class="text-content-500 text-[13px]">Wszystkie inwentaryzacje · {{ pager.nbResults }} pozycji</p>
        </div>
        {% if is_granted('ROLE_WAREHOUSE_MANAGER') %}
            <a
                href="{{ path('app_stocktaking_new') }}"
                class="flex items-center gap-2 h-[34px] px-4 text-[13px] font-medium text-white bg-brand-500 rounded-lg hover:bg-brand-400 transition-colors"
            >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>
                Nowa inwentaryzacja
            </a>
        {% endif %}
    </div>

    {{ include('stocktaking/list.html.twig') }}
</turbo-frame>
{% endblock %}
