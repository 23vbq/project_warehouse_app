{% extends 'base.html.twig' %}

{% block body %}
<div class="flex min-h-screen bg-surface-950">

    {% include 'layout/_partials/sidebar.html.twig' %}

    <div class="flex-1 flex flex-col min-w-0">

        <header class="h-14 bg-surface-900 border-b border-stroke sticky top-0 z-10 flex items-center gap-4 px-6 shrink-0">
            <nav class="flex items-center gap-2 text-[13px] text-content-500">
                {% block breadcrumb %}
                    <span>Magazyn</span>
                    <span class="text-content-700">/</span>
                    <span class="text-content-50 font-medium">{% block breadcrumb_current %}{% endblock %}</span>
                {% endblock %}
            </nav>

            <div class="ml-auto flex items-center gap-1.5">
                <div class="flex items-center gap-2 bg-surface-700 border border-stroke rounded-[10px] h-[34px] px-3 w-72 text-[13px] text-content-500 mr-4">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.3-4.3"></path></svg>
                    <input class="bg-transparent border-0 outline-none flex-1 min-w-0 text-content-50 placeholder:text-content-700 text-[13px]" placeholder="Szukaj SKU, dokumentu, lokalizacji…">
                    <kbd class="font-mono text-[10.5px] bg-surface-900 border border-stroke px-1.5 py-0.5 rounded text-content-500 shrink-0 uppercase">ctrl + K</kbd>
                </div>

                <button class="w-8 h-8 rounded-md grid place-items-center text-content-500 hover:text-content-50 hover:bg-surface-700 relative transition-colors" title="Powiadomienia">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 rounded-full bg-danger-500 shadow-[0_0_0_2px_var(--color-surface-900)]"></span>
                </button>

                <a href="{{ path('app_logout') }}" class="flex items-center gap-1.5 h-8 px-3 rounded-md bg-surface-700 border border-stroke text-content-300 hover:text-content-50 hover:border-stroke-strong text-[12.5px] font-medium transition-colors ml-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><path d="M16 17l5-5-5-5M21 12H9"></path></svg>
                    Wyloguj
                </a>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-7">
            {% block content %}{% endblock %}
        </main>

    </div>
</div>
{% endblock %}
