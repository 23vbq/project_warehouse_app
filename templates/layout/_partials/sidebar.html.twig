<aside class="w-[232px] shrink-0 bg-surface-900 border-r border-stroke flex flex-col h-screen sticky top-0 select-none">

    <div class="h-14 px-[18px] border-b border-stroke flex items-center justify-between shrink-0">
        <div class="flex items-center gap-2.5">
            {# <div class="w-7 h-7 rounded-[8px] border border-stroke-strong grid place-items-center brand-mark-bg shrink-0">
                <div class="w-1.5 h-1.5 rounded-full bg-brand-500 glow-brand-dot"></div>
            </div> #}
            <div class="w-7 h-7">{{ source('svg/app_icon.svg') }}</div>
            <div class="font-semibold text-[13.5px] tracking-tight text-content-50 leading-tight">
                RimFlowMS
                <span class="block text-[11px] text-content-700 font-medium -mt-0.5">Warehouse</span>
            </div>
        </div>
        <button class="w-7 h-7 rounded-md grid place-items-center text-content-500 hover:text-content-50 hover:bg-surface-700 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
        </button>
    </div>

    <nav class="flex-1 px-3 py-3.5 overflow-y-auto">

        <div class="mb-[18px]">
            <p class="text-[10.5px] uppercase tracking-[0.08em] text-content-700 px-2.5 pb-2 pt-1.5 font-semibold">Magazyn</p>

            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: 'app_dashboard',
                path: path('app_dashboard'),
                label: 'Pulpit',
                svgContent: source('svg/menu/dashboard.svg')
            } %}

            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: 'app_product_index',
                path: path('app_product_index'),
                label: 'Produkty',
                svgContent: source('svg/menu/products.svg'),
                alert: alerts['products'],
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Felgi gotowe',
                svgContent: source('svg/menu/finished-wheels.svg'),
                isSubitem: true,
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Półprodukty',
                svgContent: source('svg/menu/semiproducts.svg'),
                isSubitem: true,
                alert: alerts['semiproducts'],
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Surowce',
                svgContent: source('svg/menu/raw-materials.svg'),
                isSubitem: true,
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Materiały eksploatacyjne',
                svgContent: source('svg/menu/consumables.svg'),
                isSubitem: true,
            } %}
        </div>

        <div class="mb-[18px]">
            <p class="text-[10.5px] uppercase tracking-[0.08em] text-content-700 px-2.5 pb-2 pt-1.5 font-semibold">Operacje</p>

            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Operacje',
                svgContent: source('svg/menu/operations.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Przyjęcia',
                svgContent: source('svg/menu/receipts.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Wydania',
                svgContent: source('svg/menu/issues.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Przesunięcia MM',
                svgContent: source('svg/menu/mm-transfers.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Inwentaryzacja',
                svgContent: source('svg/menu/inventory.svg')
            } %}
        </div>

        <div class="mb-[18px]">
            <p class="text-[10.5px] uppercase tracking-[0.08em] text-content-700 px-2.5 pb-2 pt-1.5 font-semibold">Zarządzanie</p>

            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Lokalizacje',
                svgContent: source('svg/menu/locations.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Kontrahenci',
                svgContent: source('svg/menu/contractors.svg')
            } %}
            {% include 'layout/_partials/sidebar_item.html.twig' with {
                currentRoute: currentRoute,
                route: null,
                path: '#',
                label: 'Raporty',
                svgContent: source('svg/menu/reports.svg')
            } %}
        </div>

        {% if is_granted('ROLE_WAREHOUSE_MANAGER') %}
            <div>
                <p class="text-[10.5px] uppercase tracking-[0.08em] text-content-700 px-2.5 pb-2 pt-1.5 font-semibold">System</p>

                {% include 'layout/_partials/sidebar_item.html.twig' with {
                    currentRoute: currentRoute,
                    route: null,
                    path: '#',
                    label: 'Ustawienia',
                    svgContent: source('svg/menu/settings.svg')
                } %}
            </div>
        {% endif %}

    </nav>

    <div class="border-t border-stroke p-3 shrink-0">
        <div
            data-dropdown-toggle="sidebar-user-dropdown"
            data-dropdown-placement="right-end"
            data-dropdown-offset-distance="18"
            class="flex items-center gap-2.5 p-2 rounded-[10px] hover:bg-surface-800 cursor-pointer transition-colors"
        >
            <div class="w-[30px] h-[30px] rounded-full shrink-0 grid place-items-center text-white font-semibold text-[12px] bg-[linear-gradient(135deg,oklch(0.55_0.18_295),oklch(0.65_0.16_320))]">
                {{ app.user.getUserIdentifier()|replace({'.': ''})|upper|slice(0, 2) }}
            </div>
            <div class="flex flex-col min-w-0 flex-1">
                <span class="text-[13px] text-content-50 truncate">{{ app.user.getUserIdentifier() }}</span>
                <span class="text-[11px] text-content-700 truncate">{{ app.user.roles|map(r => constant('App\\Entity\\User::ROLE_LABELS')[r])|join(', ') }}</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-content-700 shrink-0"><path d="M9 18l6-6-6-6"></path></svg>
        </div>
        <div id="sidebar-user-dropdown" class="hidden absolute bottom-full mb-2 w-48 bg-surface-900 border border-stroke rounded-md py-2">
            <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-content-500 hover:bg-surface-800 hover:text-content-50">Wyloguj się</a>
        </div>
    </div>
</aside>
