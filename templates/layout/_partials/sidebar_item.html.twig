{% if isSubitem is not defined %}{% set isSubitem = false %}{% endif %}

{% set isActive = false %}
{% if route is not null and currentRoute == route %}
    {% if matchParams is defined %}
        {% set paramsMatch = true %}
        {% for key, value in matchParams %}
            {% if value is null %}
                {% if currentParams[key] is defined and currentParams[key] is not empty %}
                    {% set paramsMatch = false %}
                {% endif %}
            {% else %}
                {% if currentParams[key] is not defined or currentParams[key] != value %}
                    {% set paramsMatch = false %}
                {% endif %}
            {% endif %}
        {% endfor %}
        {% set isActive = paramsMatch %}
    {% else %}
        {% set isActive = true %}
    {% endif %}
{% endif %}
<a
    href="{{ path }}"
    class="flex items-center gap-2.5 px-2.5 py-2 my-px rounded-md text-[13.5px] w-full border no-underline transition-colors duration-100
    {% if isSubitem %}pl-8{% endif %}
    {% if isActive %}
        bg-brand-500/16 text-brand-400 border-brand-500/45
    {% else %}
        {% if isSubitem %}text-content-500{% else %}text-content-300{% endif %} border-transparent hover:bg-surface-800 hover:text-content-50
    {% endif %}
    "
>
    <div class="w-4 h-4 shrink-0">{{ svgContent|raw }}</div>
    {{ label }}
    {% if alert is defined and alert %}
        <span
            class="ml-auto text-xs font-medium px-2 py-0.5 rounded-full
            {% if isActive %}
                bg-brand-500/16 text-brand-400
            {% else %}
                bg-surface-800 text-content-500
            {% endif %}
            "
        >
            {{ alert }}
        </span>
    {% endif %}
</a>