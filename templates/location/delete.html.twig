<turbo-frame id="location_delete">

<form
    method="post"
    action="{{ path('app_location_delete', {id: location.id}) }}"
    class="flex flex-col"
    novalidate
    autocomplete="off"
>
    <input
        type="hidden"
        name="_token"
        value="{{ csrf_token('delete' ~ location.id) }}"
    >

    <div class="px-[22px] py-[18px] flex flex-col gap-4">
        <div class="flex items-start gap-4">
            <div>
                <p class="text-[13.5px] font-medium text-content-50 mb-1">Usunąć lokalizację <span class="text-content-300">{{ location.name }}</span>?</p>
                <p class="text-[12.5px] text-content-500 leading-relaxed">Lokalizacja zostanie usunięta z bazy danych.</p>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
            <div class="flex flex-col gap-0.5 px-3 py-2.5 bg-surface-800 border border-stroke rounded-lg">
                <span class="text-[10.5px] text-content-700">Kod</span>
                <span class="text-[12.5px] font-mono text-content-300">{{ location.code }}</span>
            </div>
            <div class="flex flex-col gap-0.5 px-3 py-2.5 bg-surface-800 border border-stroke rounded-lg">
                <span class="text-[10.5px] text-content-700">Nazwa</span>
                <span class="text-[12.5px] font-medium text-content-300">{{ location.name }}</span>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-end gap-2 px-[22px] py-4 border-t border-stroke shrink-0">
        <button
            type="button"
            data-modal-hide="modal-location-delete"
            class="h-[34px] px-4 text-[13px] font-medium text-content-300 bg-surface-800 border border-stroke rounded-lg hover:bg-surface-700 hover:text-content-50 transition-colors cursor-pointer"
        >
            Anuluj
        </button>
        <button
            type="submit"
            class="h-[34px] px-4 text-[13px] font-medium text-white bg-danger-500 rounded-lg hover:bg-danger-400 transition-colors cursor-pointer"
        >
            Usuń
        </button>
    </div>

</form>

</turbo-frame>
