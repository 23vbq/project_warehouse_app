<turbo-frame id="location-stock-details-{{ location.id }}">
    {% if stocks is empty %}
        <p class="px-4 py-3 text-[13px] text-content-500">Brak stanów magazynowych dla tej lokalizacji.</p>
    {% else %}
        <table class="w-full text-[13px] table-fixed">
            <colgroup>
                <col class="w-[15%]">
                <col class="w-[35%]">
                <col class="w-[15%]">
                <col>
            </colgroup>
            <thead>
                <tr class="border-b border-stroke">
                    <th class="px-4 py-2 text-left font-medium text-content-500">SKU</th>
                    <th class="px-4 py-2 text-left font-medium text-content-500">Produkt</th>
                    <th class="px-4 py-2 text-right font-medium text-content-500">Ilość</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-stroke">
                {% for stock in stocks %}
                    <tr>
                        <td class="px-4 py-2 font-mono text-content-50 truncate">
                            <a href="{{ path('app_product_show', {id: stock.product.id}) }}" class="font-medium underline hover:text-content-300 transition-colors">{{ stock.product.sku }}</a>
                        </td>
                        <td class="px-4 py-2 text-content-300 truncate">{{ stock.product.name }}</td>
                        <td class="px-4 py-2 text-right font-mono text-content-300">
                            {{ stock.quantity }} <span class="text-content-600">{{ stock.product.unit }}</span>
                        </td>
                        <td></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</turbo-frame>
