<turbo-frame id="location_new">

{{ form_start(form, {action: path('app_location_new'), attr: {class: 'flex flex-col', novalidate: 'novalidate', autocomplete: 'off'}}) }}

<div class="px-[22px] py-[18px] flex flex-col gap-[18px]">

    <div>
        <div class="flex items-center gap-2 mb-3">
            <span class="text-[10.5px] uppercase tracking-[0.08em] font-semibold text-content-700">Dane lokalizacji</span>
            <span class="flex-1 h-px bg-stroke"></span>
        </div>
        <div class="grid grid-cols-2 gap-x-4 gap-y-4">
            <div>
                {{ form_label(form.code, 'Kod', {label_attr: {class: 'block text-xs font-medium mb-1.5 ' ~ (form.code.vars.errors|length ? 'text-danger-500' : 'text-content-500')}}) }}
                <span class="input-wrap {{ form.code.vars.errors|length ? 'input-wrap--error' }}">
                    {{ form_widget(form.code, {attr: {placeholder: 'np. MAG-01'}}) }}
                </span>
                {% for error in form.code.vars.errors %}<p class="text-xs mt-1.5" style="color:var(--color-danger-500)">{{ error.message }}</p>{% endfor %}
            </div>
            <div>
                {{ form_label(form.name, 'Nazwa', {label_attr: {class: 'block text-xs font-medium mb-1.5 ' ~ (form.name.vars.errors|length ? 'text-danger-500' : 'text-content-500')}}) }}
                <span class="input-wrap {{ form.name.vars.errors|length ? 'input-wrap--error' }}">
                    {{ form_widget(form.name, {attr: {placeholder: 'np. Magazyn główny'}}) }}
                </span>
                {% for error in form.name.vars.errors %}<p class="text-xs mt-1.5" style="color:var(--color-danger-500)">{{ error.message }}</p>{% endfor %}
            </div>
            <div class="col-span-2">
                {{ form_label(form.description, 'Opis', {label_attr: {class: 'block text-xs font-medium mb-1.5 ' ~ (form.description.vars.errors|length ? 'text-danger-500' : 'text-content-500')}}) }}
                {{ form_widget(form.description, {attr: {placeholder: 'np. Główny magazyn w siedzibie', rows: 3, class: 'input-textarea ' ~ (form.description.vars.errors|length ? 'input-textarea--error' : '')}}) }}
                {% for error in form.description.vars.errors %}<p class="text-xs mt-1.5" style="color:var(--color-danger-500)">{{ error.message }}</p>{% endfor %}
            </div>
        </div>
    </div>

</div>

<div class="flex items-center justify-end gap-2 px-[22px] py-4 border-t border-stroke shrink-0">
    <button
        type="button"
        data-modal-hide="modal-location-new"
        class="h-[34px] px-4 text-[13px] font-medium text-content-300 bg-surface-800 border border-stroke rounded-lg hover:bg-surface-700 hover:text-content-50 transition-colors cursor-pointer"
    >
        Anuluj
    </button>
    <button
        type="submit"
        class="h-[34px] px-4 text-[13px] font-medium text-white bg-brand-500 rounded-lg hover:bg-brand-400 transition-colors cursor-pointer"
    >
        Zapisz lokalizację
    </button>
</div>

{{ form_end(form) }}

</turbo-frame>
